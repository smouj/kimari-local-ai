{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kimari.ai/schemas/kimari_sft_item.schema.json",
  "title": "KimariSFTItem",
  "description": "Schema for a single Kimari SFT v1 training example",
  "type": "object",
  "required": ["id", "category", "language", "source", "license", "quality_score", "tags", "messages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$",
      "description": "Unique identifier for this example"
    },
    "category": {
      "type": "string",
      "enum": [
        "spanish_technical",
        "coding_debug",
        "server_ops",
        "local_llm_cuda_gguf",
        "openclaw_agents",
        "safety_refusal",
        "json_tooling",
        "style_consistency"
      ],
      "description": "Category of this training example"
    },
    "language": {
      "type": "string",
      "enum": ["es", "en", "mixed"],
      "description": "Primary language of this example"
    },
    "source": {
      "type": "string",
      "description": "Origin of this example"
    },
    "license": {
      "type": "string",
      "enum": ["project-owned", "MIT", "Apache-2.0", "BSD-3-Clause", "CC-BY-4.0", "CC-BY-SA-4.0"],
      "description": "License under which this example can be redistributed"
    },
    "quality_score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Quality score: 1=placeholder, 2=draft, 3=acceptable, 4=good, 5=excellent"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "maxItems": 10,
      "description": "Tags for filtering and categorization"
    },
    "messages": {
      "type": "array",
      "minItems": 2,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": {
            "type": "string",
            "minLength": 10,
            "maxLength": 4096
          }
        }
      },
      "description": "Conversation messages in chat format"
    }
  },
  "additionalProperties": false
}