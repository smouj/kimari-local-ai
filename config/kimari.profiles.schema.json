{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kimari GPU Profiles Configuration",
  "type": "object",
  "required": ["version", "default_profile", "profiles"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Schema version"
    },
    "default_profile": {
      "type": "string",
      "description": "Default GPU profile to use"
    },
    "server": {
      "type": "object",
      "properties": {
        "health_endpoint": { "type": "string" },
        "chat_endpoint": { "type": "string" },
        "models_endpoint": { "type": "string" }
      }
    },
    "profiles": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9_]+$": {
          "type": "object",
          "required": ["name", "model", "ctx", "batch", "ubatch", "host", "port", "gpu_layers", "quantization"],
          "properties": {
            "name": { "type": "string" },
            "model": { "type": "string", "description": "Path to GGUF model file" },
            "ctx": { "type": "integer", "minimum": 512 },
            "batch": { "type": "integer", "minimum": 1 },
            "ubatch": { "type": "integer", "minimum": 1 },
            "cache_type_k": { "type": "string", "enum": ["f16", "q8_0", "q4_0", "fp16"] },
            "cache_type_v": { "type": "string", "enum": ["f16", "q8_0", "q4_0", "fp16"] },
            "host": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "gpu_layers": { "type": ["string", "integer"] },
            "threads": { "type": "integer", "minimum": 1 },
            "vram_total_gb": { "type": "number", "minimum": 0 },
            "vram_safe_gb": { "type": "number", "minimum": 0 },
            "quantization": { "type": "string" },
            "estimated_model_size_gb": { "type": "number", "description": "Estimated model file size in GiB (approximate)" },
            "notes": { "type": "string" }
          }
        }
      }
    }
  }
}
